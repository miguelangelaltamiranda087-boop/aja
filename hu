import tkinter as tk
from tkinter import messagebox
import os  # 🔥 necesario para validar archivos

# Lista de dispositivos
dispositivos = []

# Consumo por tipo (kWh)
consumos = {
    "Aire acondicionado": 1.5,
    "Computador": 0.3,
    "Impresora": 0.1,
    "Luces": 0.05
}

# Cantidad de luces por defecto
cantidad_luces = 10


# AGREGAR DISPOSITIVO
def agregar():
    nombre = dispositivo_var.get()
    tiempo = entry_tiempo.get()

    if tiempo == "":
        messagebox.showerror("Error", "Ingrese las horas")
        return

    try:
        tiempo = int(tiempo)
        if tiempo < 0:
            raise ValueError
    except:
        messagebox.showerror("Error", "Tiempo inválido")
        return

    # 🔥 Lógica especial luces
    if nombre == "Luces":
        consumo_hora = consumos[nombre] * cantidad_luces
    else:
        consumo_hora = consumos[nombre]

    dispositivos.append({
        "nombre": nombre,
        "tiempo": tiempo,
        "consumo_hora": consumo_hora
    })

    # Mostrar en lista
    if nombre == "Luces":
        lista.insert(tk.END, f"{nombre} ({cantidad_luces}) - {tiempo}h")
    else:
        lista.insert(tk.END, f"{nombre} - {tiempo}h")

    entry_tiempo.delete(0, tk.END)


# MOSTRAR REPORTE
def mostrar():
    if len(dispositivos) == 0:
        messagebox.showwarning("Aviso", "No hay dispositivos")
        return

    resultado.delete("1.0", tk.END)

    consumo_total = 0
    resultado.insert(tk.END, "------ REPORTE OFICINA ------\n")

    for d in dispositivos:
        consumo = d["tiempo"] * d["consumo_hora"]
        consumo_total += consumo

        resultado.insert(tk.END, f"\n{d['nombre']}\n")
        resultado.insert(tk.END, f"Horas: {d['tiempo']}\n")
        resultado.insert(tk.END, f"Consumo: {consumo:.2f} kWh\n")

    resultado.insert(tk.END, "\n------ TOTAL ------\n")
    resultado.insert(tk.END, f"{consumo_total:.2f} kWh\n")


# 🔥 GUARDAR SIN SOBRESCRIBIR
def guardar():
    if len(dispositivos) == 0:
        messagebox.showwarning("Aviso", "Nada que guardar")
        return

    contador = 1

    # Buscar nombre disponible
    while True:
        nombre_archivo = f"reporte_{contador}.txt"
        if not os.path.exists(nombre_archivo):
            break
        contador += 1

    with open(nombre_archivo, "w") as f:
        consumo_total = 0
        f.write("------ REPORTE OFICINA ------\n")

        for d in dispositivos:
            consumo = d["tiempo"] * d["consumo_hora"]
            consumo_total += consumo

            f.write(f"\n{d['nombre']}\n")
            f.write(f"Horas: {d['tiempo']}\n")
            f.write(f"Consumo: {consumo:.2f} kWh\n")

        f.write("\n------ TOTAL ------\n")
        f.write(f"{consumo_total:.2f} kWh\n")

    messagebox.showinfo("Guardado", f"Archivo guardado como {nombre_archivo}")


# VENTANA
ventana = tk.Tk()
ventana.title("Consumo Energético Oficina")
ventana.geometry("400x500")
ventana.configure(bg="#1e1e2f")

# Dropdown
tk.Label(ventana, text="Tipo de dispositivo", bg="#1e1e2f", fg="white").pack()

dispositivo_var = tk.StringVar()
dispositivo_var.set("Computador")

menu = tk.OptionMenu(ventana, dispositivo_var, *consumos.keys())
menu.pack()

# Input horas
tk.Label(ventana, text="Horas de uso", bg="#1e1e2f", fg="white").pack()
entry_tiempo = tk.Entry(ventana, bg="#2e2e3e", fg="white")
entry_tiempo.pack()

# Botones
tk.Button(ventana, text="Agregar", bg="#4CAF50", fg="white", command=agregar).pack(pady=5)
tk.Button(ventana, text="Mostrar reporte", bg="#2196F3", fg="white", command=mostrar).pack(pady=5)
tk.Button(ventana, text="Guardar", bg="#FF9800", fg="white", command=guardar).pack(pady=5)

# Lista
lista = tk.Listbox(ventana, bg="#2e2e3e", fg="white")
lista.pack(pady=10, fill=tk.BOTH)

# Resultado
resultado = tk.Text(ventana, height=12, bg="#2e2e3e", fg="white")
resultado.pack(pady=10)

ventana.mainloop()